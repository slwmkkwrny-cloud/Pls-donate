-- ============================================================
-- ANIMATE IN
-- ============================================================
local function animateIn(frame)
    local w = frame.AbsoluteSize.X
    local h = frame.AbsoluteSize.Y
    frame.Position = UDim2.new(0.5, -w/2, 1, 60)
    TweenService:Create(frame,
        TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        { Position = UDim2.new(0.5, -w/2, 0.5, -h/2) }
    ):Play()
end

-- ============================================================
-- ANIMATE OUT
-- ============================================================
local function animateOut(frame, overlay, callback)
    local w = frame.AbsoluteSize.X
    local t = TweenService:Create(frame,
        TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In),
        { Position = UDim2.new(0.5, -w/2, 1, 80) }
    )
    t:Play()
    t.Completed:Connect(function()
        if overlay then overlay:Destroy() end
        frame:Destroy()
        if callback then callback() end
    end)
end

