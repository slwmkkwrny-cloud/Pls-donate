-- ============================================================
-- DRAW ROBUX ICON - לבן, קטן
-- ============================================================
local function drawRobuxIcon(parent, px, py, size, zindex)
    local WHITE = Color3.fromRGB(255, 255, 255)
    local BG    = Color3.fromRGB(18, 18, 18)

    local container = Instance.new("Frame")
    container.Size = UDim2.new(0, size, 0, size)
    container.Position = UDim2.new(0, px, 0, py)
    container.BackgroundTransparency = 1
    container.BorderSizePixel = 0
    container.ZIndex = zindex
    container.Parent = parent

    local outer = Instance.new("Frame")
    outer.Size = UDim2.new(0, size, 0, size)
    outer.AnchorPoint = Vector2.new(0.5, 0.5)
    outer.Position = UDim2.new(0.5, 0, 0.5, 0)
    outer.BackgroundColor3 = WHITE
    outer.BorderSizePixel = 0
    outer.Rotation = 30
    outer.ZIndex = zindex
    outer.Parent = container
    Instance.new("UICorner", outer).CornerRadius = UDim.new(0, math.floor(size * 0.22))

    local rp = math.floor(size * 0.12)
    local rSize = size - rp * 2
    local ringFrame = Instance.new("Frame")
    ringFrame.Size = UDim2.new(0, rSize, 0, rSize)
    ringFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    ringFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    ringFrame.BackgroundColor3 = BG
    ringFrame.BorderSizePixel = 0
    ringFrame.Rotation = 30
    ringFrame.ZIndex = zindex + 1
    ringFrame.Parent = container
    Instance.new("UICorner", ringFrame).CornerRadius = UDim.new(0, math.floor(rSize * 0.22))

    local ip = math.floor(size * 0.09)
    local iSize = rSize - ip * 2
    local inner = Instance.new("Frame")
    inner.Size = UDim2.new(0, iSize, 0, iSize)
    inner.AnchorPoint = Vector2.new(0.5, 0.5)
    inner.Position = UDim2.new(0.5, 0, 0.5, 0)
    inner.BackgroundColor3 = WHITE
    inner.BorderSizePixel = 0
    inner.Rotation = 30
    inner.ZIndex = zindex + 2
    inner.Parent = container
    Instance.new("UICorner", inner).CornerRadius = UDim.new(0, math.floor(iSize * 0.22))

    local hSize = math.floor(iSize * 0.44)
    local sq = Instance.new("Frame")
    sq.Size = UDim2.new(0, hSize, 0, hSize)
    sq.AnchorPoint = Vector2.new(0.5, 0.5)
    sq.Position = UDim2.new(0.5, 0, 0.5, 0)
    sq.BackgroundColor3 = BG
    sq.BorderSizePixel = 0
    sq.ZIndex = zindex + 3
    sq.Parent = container
    Instance.new("UICorner", sq).CornerRadius = UDim.new(0, math.floor(hSize * 0.15))

    return container
end

